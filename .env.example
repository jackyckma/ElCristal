# ElCristal — Environment Configuration
# Copy this file to .env and fill in your values before running docker compose up

# ── Email notification ──────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key-here

# ── Processing limits ────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100
MAX_BATCH_SIZE=50
OUTPUT_TTL_HOURS=72

# ── Infrastructure ───────────────────────────────────────────────────────────
# Public URL for download links in notification emails
BASE_URL=http://localhost:7860

# Number of concurrent pipeline workers (keep at 1 for CPU-only deployments)
WORKER_CONCURRENCY=1

# Set to true if the worker host has a CUDA-capable GPU
# Also uncomment the GPU deploy section in docker-compose.yml
USE_GPU=false

# Path inside containers where model weights are cached
MODEL_CACHE_DIR=/models

# ── Single-container deploys (Zeabur, HF Spaces, etc.) ────────────────────────
# When true, the gradio container runs the ML pipeline in-process and skips
# the Redis/RQ queue. Used by the root Dockerfile. Leave false for the
# multi-container docker-compose setup (web + worker + redis).
INLINE_MODE=false
